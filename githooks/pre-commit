#!/bin/sh
# Format staged files with Prettier before committing. lint-staged runs the
# task on the staged files only and re-stages whatever it reformats.
# Run the locally-installed binary directly rather than via npx, which would
# silently install lint-staged if it were missing.
#
# This hook is version-controlled. Activate it with:
#   ln -s ../../githooks/pre-commit .git/hooks/pre-commit
./node_modules/.bin/lint-staged
